<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_default"
    android:paddingStart="@dimen/standard_padding"
    android:paddingRight="@dimen/standard_padding"
    android:paddingBottom="@dimen/standard_padding">


    <ImageView
        android:id="@+id/icon"
        android:layout_width="0dp"
        android:layout_height="@dimen/activity_icon_height"
        android:alpha="0.5"
        android:contentDescription="@string/activity_icon"
        android:padding="2dp"
        android:src="@drawable/ic_activity"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/subject"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/standard_eighth_margin"
        android:ellipsize="end"
        android:paddingTop="@dimen/standard_padding"
        android:textAppearance="?android:attr/textAppearanceListItem"
        android:textColor="@color/text_color"
        android:textSize="@dimen/txt_size_17sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/overflowMenu"
        app:layout_constraintStart_toEndOf="@id/icon"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="John Doe" />

    <ImageView
        android:id="@+id/overflowMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:paddingStart="2dp"
        android:visibility="gone"
        tools:visibility="visible"
        android:paddingTop="@dimen/standard_padding"
        android:src="@drawable/ic_dots_vertical"
        app:layout_constraintBottom_toBottomOf="@id/subject"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/subject"
        app:layout_constraintTop_toTopOf="@id/subject"
        app:tint="@color/primary" />

    <TextView
        android:id="@+id/datetime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/standard_quarter_margin"
        android:ellipsize="end"
        android:textColor="@color/secondary_text_color"
        android:textSize="@dimen/txt_size_17sp"
        app:layout_constraintBottom_toTopOf="@id/message"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/icon"
        app:layout_constraintTop_toBottomOf="@id/subject"
        tools:text="3 seconds ago" />

    <TextView
        android:id="@+id/message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="4"
        android:textAppearance="?android:attr/textAppearanceListItem"
        android:textColor="@color/text_color"
        android:textSize="@dimen/txt_size_17sp"
        app:layout_constraintBottom_toTopOf="@id/list"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/icon"
        app:layout_constraintTop_toBottomOf="@id/datetime"
        tools:text="Lorem ipsum dolor sit ame" />

    <GridLayout
        android:id="@+id/list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/activity_list_item_grid_layout_left_start_margin"
        android:layout_marginTop="@dimen/alternate_half_margin"
        android:layout_marginBottom="@dimen/standard_eighth_margin"
        android:columnCount="3"
        android:paddingStart="@dimen/activity_icon_layout_right_end_margin"
        android:paddingEnd="@dimen/zero"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/message" />

</androidx.constraintlayout.widget.ConstraintLayout>